## SKALE merchant config

# Your SKALE (EVM) address to receive payments. Required.
RECEIVING_ADDRESS=

# SKALE Base chain to settle on.
#   324705682   = SKALE Base Sepolia Testnet (default — safe for dev)
#   1187947933  = SKALE Base Mainnet (production)
# Docs: https://docs.skale.space/get-started/quick-start/skale-on-base
# SKALE_CHAIN_ID=324705682

# Payment token. Default = SKALE Base Sepolia bridged USDC.
# For mainnet, supply the mainnet token address (not yet in public docs — ask in
# SKALE Builders Chat: https://t.me/+qYNC0AACARc3ODUx).
# PAYMENT_TOKEN_ADDRESS=0x2e08028E3C4c2356572E096d8EF835cD5C6030bD

# DirtRoad's x402 facilitator. Override only if you're running your own.
# FACILITATOR_URL=https://facilitator.dirtroad.dev

## AgentTax — US sales tax compliance (free tier: 100 calls/mo at agenttax.io/pricing)

AGENTTAX_API_KEY=

# Fallback buyer state for tax calc when the request doesn't carry one (2-letter US state).
AGENTTAX_DEFAULT_STATE=TX
